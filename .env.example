# Copy to .env and adjust as needed: `cp .env.example .env`
# Consumed by docker-compose.yml (root) for the full-stack deployment.

# ----- Backend -----
RUST_LOG=info
ADMIN_SECRET=dev-admin-secret
CORS_ORIGIN=http://localhost:5173

# ----- Host port mappings -----
BACKEND_PORT=3000
WEB_PORT=5173

# Public origin the browser uses to reach the web app. adapter-node validates
# form POSTs (CSRF) against this — it must match WEB_PORT above.
WEB_ORIGIN=http://localhost:5173
