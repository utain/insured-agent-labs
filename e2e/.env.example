# Copy to .env (`cp .env.example .env`) — auto-loaded by the Playwright config.
# Point the suite at whichever running app you want to test (local, docker, staging).

# App base URL — the single SvelteKit origin serves both the UI and the API.
BASE_URL=http://localhost:5173

# Optional overrides (default to BASE_URL).
# API_BASE_URL=http://localhost:5173
# WEB_BASE_URL=http://localhost:5173

# Shared demo password for all seeded agents.
DEMO_PASSWORD=insure_demo
