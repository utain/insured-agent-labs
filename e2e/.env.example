# Copy to .env (`cp .env.example .env`) — auto-loaded by the Playwright config.
# Point the suite at whichever running stack you want to test (local native,
# docker compose, a remote/staging deployment, ...).

# Rust backend base URL (API/integration tests hit this directly).
API_BASE_URL=http://localhost:3000

# SvelteKit web app base URL (UI/e2e tests drive the browser here).
WEB_BASE_URL=http://localhost:5173

# Shared demo password for all seeded agents.
DEMO_PASSWORD=insure_demo
